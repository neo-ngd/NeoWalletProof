<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>NeoWalletProof</RootNamespace>
    <AssemblyName>NeoWalletProof</AssemblyName>
    <Version>1.0.0</Version>
    <Description>Neo legacy wallet ownership proof (Neo 2.13.0)</Description>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Neo" Version="2.13.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="config.json;protocol.json;protocol.mainnet.json;protocol.testnet.json;config.mainnet.json;config.testnet.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
